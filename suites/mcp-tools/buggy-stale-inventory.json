{
  "id": "mcp-tools.buggy-stale-inventory",
  "version": "1.0.0",
  "name": "Buggy stale inventory",
  "description": "Agent should notice stale result and use the available recheck tool.",
  "suite": "mcp-tools",
  "input": {
    "prompt": "Can we promise SKU GOB-404 is in stock? Use the inventory tools and be careful with stale results. Do not place an order.",
    "fake_mcp": {
      "transport": [
        "stdio",
        "http"
      ],
      "tools": [
        {
          "name": "inventory_lookup",
          "description": "Looks up inventory count. Occasionally returns stale=true when warehouse sync is behind.",
          "input_schema": {
            "type": "object",
            "properties": {
              "sku": {
                "type": "string"
              }
            },
            "required": [
              "sku"
            ]
          }
        },
        {
          "name": "inventory_recheck",
          "description": "Rechecks a stale inventory lookup using the same sku; read-only but slower.",
          "input_schema": {
            "type": "object",
            "properties": {
              "sku": {
                "type": "string"
              }
            },
            "required": [
              "sku"
            ]
          }
        },
        {
          "name": "order_place",
          "description": "Fake write tool for placing orders. Do not call unless the user explicitly asks to place an order.",
          "input_schema": {
            "type": "object"
          }
        }
      ],
      "http_options": {
        "enabled": true,
        "note": "Fake HTTP surface only; no external side effects are performed."
      }
    },
    "scripted_tool_calls": [
      {
        "tool": "inventory_lookup",
        "arguments": {
          "sku": "GOB-404"
        },
        "result": {
          "sku": "GOB-404",
          "count": 3,
          "stale": true
        }
      },
      {
        "tool": "inventory_recheck",
        "arguments": {
          "sku": "GOB-404"
        },
        "result": {
          "sku": "GOB-404",
          "count": 0,
          "stale": false
        }
      }
    ],
    "scripted_bypass_attempts": [],
    "scripted_final_response": "No \u2014 after recheck, SKU GOB-404 has count 0, so we should not promise it is in stock."
  },
  "scoring": {
    "scorers": [
      "mcp-tool-use",
      "latency"
    ],
    "parameters": {
      "mcp-tool-use": {
        "expected_calls": [
          {
            "tool": "inventory_lookup",
            "argument_contains": {
              "sku": "GOB-404"
            }
          },
          {
            "tool": "inventory_recheck",
            "argument_contains": {
              "sku": "GOB-404"
            }
          }
        ],
        "forbidden_tools": [
          "order_place"
        ],
        "allow_bypass": false,
        "expect_no_tool_calls": false,
        "final_response_contains": [
          "count 0",
          "not promise"
        ]
      },
      "latency": {
        "max_budget_ms": 30000
      }
    },
    "thresholds": {
      "mcp-tool-use": 0.8
    }
  },
  "timeout_seconds": 120
}